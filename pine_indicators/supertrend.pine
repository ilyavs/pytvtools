//@version=6
indicator(title="Custom Supertrend", shorttitle="ST_Custom", format=format.price, precision=2, timeframe="")

period_in = input.int(10, "Period")
multiplier = input.float(3.0, "Multiplier")

// ATR using RMA with tr[0] = high[0] - low[0] (matches TV's ta.supertrend() internal ATR)
var float rma = na
tr_ = bar_index == 0 ? high - low : math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))

if na(rma)
    if bar_index == period_in - 1
        sum_tr = 0.0
        for i = 0 to period_in - 1
            tr_i = i == 0 ? high[i] - low[i] : math.max(high[i] - low[i], math.abs(high[i] - close[i + 1]), math.abs(low[i] - close[i + 1]))
            sum_tr += tr_i
        rma := sum_tr / period_in
else
    rma := (rma[1] * (period_in - 1) + tr_) / period_in

// SuperTrend
var float lowerBand = na
var float upperBand = na
var int dir = 0

if not na(rma)
    basicLower = (high + low) / 2 - multiplier * rma
    basicUpper = (high + low) / 2 + multiplier * rma

    if na(lowerBand[1])
        lowerBand := basicLower
        upperBand := basicUpper
        dir := close < basicLower ? 1 : -1
    else
        prevLower = lowerBand[1]
        prevUpper = upperBand[1]
        prevClose = close[1]

        if basicLower > prevLower or prevClose < prevLower
            lowerBand := basicLower
        else
            lowerBand := prevLower

        if basicUpper < prevUpper or prevClose > prevUpper
            upperBand := basicUpper
        else
            upperBand := prevUpper

        if dir[1] == -1
            dir := close > upperBand ? -1 : 1
        else
            dir := close < lowerBand ? 1 : -1

supertrend = dir == -1 ? lowerBand : upperBand

plot(dir == -1 ? supertrend : na, "Up Trend", color=color.green, linewidth=2)
plot(dir == 1 ? supertrend : na, "Down Trend", color=color.red, linewidth=2)
plot((high + low) / 2, "Body Middle", color=color.gray, display=display.none)
