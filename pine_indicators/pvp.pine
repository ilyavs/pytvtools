//@version=6
// Periodic Volume Profile — per-period developing POC matching built-in.
// Uses request.security_lower_tf(LOWER_TF) for lower-TF bars, builds
// a volume histogram per period, reports developing POC on each bar
// and completed-period POCs via line.new for all periods.
//
// Pine v6: always array.concat() for LTF arrays, never push() in a loop.
indicator(title="Periodic Volume Profile (Custom)", shorttitle="PVP_Custom", overlay=true, format=format.price, precision=2)

period_mult   = input.int(1, "Period Multiplier", group="Period")
period_unit   = input.string("Day", "Period Unit", options=["Day", "Week", "Month"], group="Period")
num_rows      = input.int(24, "Number of Rows", group="Rows", minval=1)

f_lower_tf() =>
    int min = int(timeframe.in_seconds(timeframe.period) / 60)
    if min <= 15
        "1"
    else if min <= 30
        "5"
    else if min <= 60
        "10"
    else if min <= 120
        "15"
    else if min <= 240
        "30"
    else
        "60"

LOWER_TF = f_lower_tf()
year_change = ta.change(time("12M"))

f_period_tf() =>
    string base = switch period_unit
        "Day"   => "D"
        "Week"  => "W"
        "Month" => "M"
    period_mult == 1 ? base : str.tostring(period_mult) + base

[hs, ls, vs] = request.security_lower_tf(syminfo.tickerid, LOWER_TF, [high, low, volume])

var float[]     period_highs      = na
var float[]     period_lows       = na
var float[]     period_volumes    = na
var int         period_start_bar  = na
var float       completed_poc     = na
var line[]      poc_lines         = array.new<line>()

tf_change = ta.change(time(f_period_tf()))
is_new_period = (not na(period_start_bar) and tf_change != 0) or (not na(period_start_bar) and year_change != 0)

if is_new_period and not na(period_start_bar) and not na(period_highs) and array.size(period_highs) > 0
    // Compute POC for completed period
    float pls_min = array.min(period_lows)
    float pls_max = array.max(period_highs)
    float price_range = pls_max - pls_min
    if price_range > 0
        float mt = syminfo.mintick
        float ticks_in_range = price_range / mt
        int tpr_down  = int(math.floor(ticks_in_range / num_rows))
        int tpr_up    = int(math.ceil(ticks_in_range / num_rows))
        tpr_down := math.max(tpr_down, 1)
        tpr_up   := math.max(tpr_up, 1)
        int rows_down = int(math.ceil(ticks_in_range / tpr_down))
        int rows_up   = int(math.ceil(ticks_in_range / tpr_up))
        int tpr_used = math.abs(rows_down - num_rows) <= math.abs(rows_up - num_rows) ? tpr_down : tpr_up
        int total_rows = int(math.ceil(ticks_in_range / tpr_used))
        float tick_size = tpr_used * mt
        
        float[] row_vols = array.new<float>(total_rows, 0.0)
        int sz = array.size(period_volumes)
        for i = 0 to sz - 1
            float bv = array.get(period_volumes, i)
            if na(bv) or bv <= 0
                continue
            float bh = array.get(period_highs, i)
            float bl = array.get(period_lows, i)
            float tick_range = (bh - bl) / mt
            int num_ticks = int(tick_range)
            num_ticks := math.max(num_ticks, 1)
            float vol_per_tick = bv / num_ticks
            for t = 0 to num_ticks
                float price = bl + t * mt
                if price > bh
                    continue
                int r = int(math.floor((price - pls_min) / tick_size))
                r := math.max(0, math.min(total_rows - 1, r))
                float cur = array.get(row_vols, r)
                array.set(row_vols, r, cur + vol_per_tick)
        float max_vol = array.max(row_vols)
        if max_vol > 0
            int poc_row = array.indexof(row_vols, max_vol)
            if poc_row == -1
                poc_row := 0
            float poc_price = pls_min + (poc_row + 0.5) * tick_size
            completed_poc := poc_price
            if array.size(poc_lines) >= 30
                line.delete(array.shift(poc_lines))
            line l = line.new(time[1], poc_price, time, poc_price, xloc=xloc.bar_time, extend=extend.right, color=color.new(#2196F3, 0), style=line.style_solid, width=1)
            array.push(poc_lines, l)
if is_new_period or na(period_start_bar)
    period_start_bar := bar_index
    period_highs := array.copy(hs)
    period_lows  := array.copy(ls)
    period_volumes := array.copy(vs)
else
    period_highs   := array.concat(period_highs, hs)
    period_lows    := array.concat(period_lows, ls)
    period_volumes := array.concat(period_volumes, vs)

plot(is_new_period ? 1.0 : 0.0, "PeriodEnd", color=color.new(color.gray, 50))
